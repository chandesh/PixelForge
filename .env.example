# ─── Django ───────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_SETTINGS_MODULE=core.config.dev
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://pixelforge:pixelforge@db:5432/pixelforge
POSTGRES_DB=pixelforge
POSTGRES_USER=pixelforge
POSTGRES_PASSWORD=pixelforge

# ─── JWT ──────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Celery ───────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─── Storage ──────────────────────────────────────────
STORAGE_BACKEND=local
MEDIA_ROOT=/app/media
MEDIA_URL=/media/

# ─── Production: switch to STORAGE_BACKEND=s3 ─────────
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_SIGNED_URL_EXPIRY=3600

# ─── Frontend ─────────────────────────────────────────
FRONTEND_URL=http://localhost:4300
CORS_ALLOWED_ORIGINS=http://localhost:4300
API_BASE_URL=http://localhost:8383
